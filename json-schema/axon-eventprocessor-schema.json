{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventProcessor",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "isStreaming": {
      "type": "boolean"
    },
    "fullName": {
      "type": "string"
    },
    "tokenStoreIdentifier": {
      "type": "string"
    },
    "activeThreads": {
      "type": "integer"
    },
    "canPause": {
      "type": "boolean"
    },
    "isRunning": {
      "type": "boolean"
    },
    "isError": {
      "type": "boolean"
    }
  }
}
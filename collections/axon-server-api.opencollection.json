                "type": "path"
              },
              {
                "name": "context",
                "value": "",
                "type": "query"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Appends a new snapshot for an aggregate."
        }
      ]
    },
